.container {
  padding: 30rpx;
}

/* 输入区域 */
.input-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.todo-input {
  flex: 1;
  height: 80rpx;
  padding: 0 30rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: white;
}

.todo-input:focus {
  border-color: #4a90e2;
}

.add-btn {
  width: 140rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #4a90e2;
  color: white;
  font-size: 28rpx;
  border-radius: 40rpx;
  padding: 0;
  margin: 0;
}

.add-btn:active {
  background: #357abd;
}

/* 统计信息 */
.stats {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.stats-text {
  font-size: 24rpx;
  color: #888;
}

.clear-btn {
  font-size: 24rpx;
  color: #e74c3c;
}

/* 待办列表 */
.todo-list {
  background: white;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.todo-item {
  display: flex;
  align-items: center;
  padding: 30rpx 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.todo-item:last-child {
  border-bottom: none;
}

.todo-item.completed .todo-text {
  text-decoration: line-through;
  color: #aaa;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 4rpx solid #ddd;
  border-radius: 50%;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.check-inner {
  width: 32rpx;
  height: 32rpx;
  background: #4a90e2;
  border-radius: 50%;
  color: white;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.todo-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  word-break: break-all;
}

.delete-btn {
  width: 60rpx;
  height: 60rpx;
  line-height: 56rpx;
  text-align: center;
  color: #e74c3c;
  font-size: 40rpx;
  flex-shrink: 0;
}

.delete-btn:active {
  background: #f5f5f5;
  border-radius: 50%;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.empty-subtext {
  display: block;
  font-size: 26rpx;
  color: #999;
}
